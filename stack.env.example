# ─── Transmission servers ────────────────────────────────────────────────────
# Path to the servers config file inside the container.
# Copy config/servers.json.example → config/servers.json and edit it.
# The file supports // and /* */ comments (JSONC).
SERVERS_FILE=/config/servers.json

# Fallback: inline JSON (used only if SERVERS_FILE does not exist).
# Useful for quick tests or single-server setups without a mounted file.
# TRANSMISSION_SERVERS=[{"name":"S1","host":"transmission-1.local","port":9091,"user":"admin","password":"changeme"}]

# ─── Cleanup rules ───────────────────────────────────────────────────────────
# Delete seeding/stopped (and fully downloaded) torrents older than this many days
DAYS_TO_WAIT=10

# Minimum upload ratio before deletion (0 = disabled)
MIN_RATIO=0

# Cron schedule for automatic cleanup (default: every Wednesday at 07:50)
CLEANUP_SCHEDULE=50 7 * * 3

# Timezone the cron schedule and displayed times are evaluated in (IANA name).
# Without this the container defaults to UTC, so CLEANUP_SCHEDULE fires at
# UTC time even though the dashboard shows it as if it were local time.
TZ=Europe/Rome

# If true, log what would be deleted but don't actually delete anything
DRY_RUN=false

# ─── Notifications ───────────────────────────────────────────────────────────
# Send notifications even when nothing was deleted (default: only on activity)
NOTIFY_ALWAYS=false

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Resend (https://resend.com)
RESEND_ENABLED=false
RESEND_API_KEY=
RESEND_FROM=cleaner@yourdomain.com
RESEND_TO=you@yourdomain.com

# SMTP (system mailer / relay)
SMTP_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=cleaner@yourdomain.com
SMTP_TO=you@yourdomain.com
# true = SMTP_SSL (port 465); false = plain/STARTTLS
SMTP_TLS=false

